{
  "version": 2,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    },
    {
      "src": "frontend-react/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "api/index.py"
    },
    {
      "src": "/assets/(.*)",
      "dest": "frontend-react/assets/$1"
    },
    {
      "src": "/(.*)",
      "dest": "frontend-react/$1",
      "continue": true
    },
    {
      "src": "/(.*)",
      "status": 404,
      "dest": "frontend-react/index.html"
    }
  ]
}
